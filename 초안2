<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>1-Minute English — Minimal Speaking Trainer</title>
  <style>
    * { box-sizing: border-box; }
    body {
      margin: 0;
      background: #ffffff;
      color: #000000;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
      -webkit-font-smoothing: antialiased;
    }
    .container {
      max-width: 1160px;
      margin: 0 auto;
      padding: 36px 20px 56px;
    }
    .topbar {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 20px;
      margin-bottom: 28px;
      border-bottom: 2px solid #000;
      padding-bottom: 18px;
    }
    h1 {
      margin: 0 0 6px;
      font-size: clamp(34px, 5vw, 56px);
      line-height: 0.95;
      letter-spacing: -0.04em;
      font-weight: 800;
    }
    .subtitle {
      font-size: 14px;
      line-height: 1.6;
      max-width: 680px;
    }
    .badge {
      border: 2px solid #000;
      padding: 8px 12px;
      font-size: 12px;
      font-weight: 700;
      white-space: nowrap;
    }
    .layout {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 26px;
      align-items: start;
    }
    .card {
      border: 2px solid #000;
      background: #fff;
      padding: 22px;
    }
    .section-title {
      font-size: 13px;
      font-weight: 800;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      margin-bottom: 14px;
    }
    .pointer {
      width: 0;
      height: 0;
      border-left: 16px solid transparent;
      border-right: 16px solid transparent;
      border-top: 22px solid #000;
      margin: 0 auto 8px;
    }
    .wheel-area {
      text-align: center;
    }
    canvas {
      width: 100%;
      max-width: 440px;
      border-radius: 50%;
      border: 6px solid #000;
      transition: transform 4.2s cubic-bezier(0.16, 1, 0.3, 1);
      display: block;
      margin: 0 auto;
      background: #fff;
    }
    .topic-box, .output-box {
      border: 2px solid #000;
      min-height: 88px;
      padding: 16px;
      margin-top: 18px;
      font-size: 21px;
      line-height: 1.35;
      font-weight: 700;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      word-break: keep-all;
    }
    .output-box {
      min-height: 160px;
      font-size: 15px;
      font-weight: 500;
      justify-content: flex-start;
      text-align: left;
      white-space: pre-wrap;
      line-height: 1.7;
    }
    .output-box.small {
      min-height: 120px;
    }
    .grid-2 {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
      margin-top: 14px;
    }
    .stack {
      display: grid;
      gap: 14px;
    }
    button {
      width: 100%;
      padding: 14px 16px;
      border: 2px solid #000;
      background: #000;
      color: #fff;
      font-weight: 800;
      font-size: 15px;
      cursor: pointer;
      border-radius: 0;
      transition: transform 0.12s ease, opacity 0.12s ease;
    }
    button:hover:not(:disabled) { transform: translateY(-1px); }
    button.secondary {
      background: #fff;
      color: #000;
    }
    button:disabled {
      opacity: 0.35;
      cursor: not-allowed;
      transform: none;
    }
    .timer-row {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
    }
    .timer-box {
      border: 2px solid #000;
      padding: 16px;
    }
    .timer-label {
      font-size: 12px;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      margin-bottom: 8px;
    }
    .timer {
      font-size: 40px;
      font-weight: 800;
      letter-spacing: -0.05em;
      line-height: 1;
    }
    .status {
      border: 2px solid #000;
      padding: 14px 16px;
      font-size: 14px;
      line-height: 1.7;
      min-height: 84px;
    }
    .helper {
      font-size: 13px;
      line-height: 1.7;
      margin-top: 10px;
    }
    .mono-title {
      font-size: 16px;
      font-weight: 800;
      margin: 6px 0 0;
    }
    .note {
      font-size: 12px;
      line-height: 1.6;
      margin-top: 10px;
    }
    audio {
      width: 100%;
      margin-top: 10px;
      filter: grayscale(100%);
    }
    .feedback-list {
      margin: 0;
      padding-left: 18px;
    }
    .feedback-list li {
      margin-bottom: 8px;
    }
    @media (max-width: 980px) {
      .layout { grid-template-columns: 1fr; }
      .grid-2, .timer-row { grid-template-columns: 1fr; }
      .topbar { flex-direction: column; }
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="topbar">
      <div>
        <h1>1-Minute<br>English</h1>
        <div class="subtitle">
          랜덤 주제를 뽑고, 1분 생각한 뒤, 1분 동안 영어로 말해보세요.
          말한 내용은 브라우저가 텍스트로 옮기고, 더 자연스러운 원어민식 표현 피드백도 함께 보여줍니다.
        </div>
      </div>
      <div class="badge">WHITE / BLACK ONLY</div>
    </div>

    <div class="layout">
      <div class="card">
        <div class="section-title">Topic Roulette</div>
        <div class="wheel-area">
          <div class="pointer"></div>
          <canvas id="wheelCanvas" width="700" height="700"></canvas>
          <div class="topic-box" id="selectedTopic">룰렛을 돌려 오늘의 주제를 선택하세요</div>
        </div>

        <div class="grid-2">
          <button id="spinBtn">룰렛 돌리기</button>
          <button id="rerollBtn" class="secondary">다시 뽑기</button>
        </div>

        <div class="helper">
          버튼 이름은 <strong>생각 정리 시작</strong>, <strong>말하기 시작</strong>으로 넣었습니다.
          간단하고 직관적이라 실제 연습 루틴으로 쓰기 좋습니다.
        </div>
      </div>

      <div class="stack">
        <div class="card">
          <div class="section-title">Practice Flow</div>
          <div class="timer-row">
            <div class="timer-box">
              <div class="timer-label">Prep Timer</div>
              <div class="timer" id="prepTimer">01:00</div>
            </div>
            <div class="timer-box">
              <div class="timer-label">Speaking Timer</div>
              <div class="timer" id="speakTimer">01:00</div>
            </div>
          </div>

          <div style="margin-top: 12px;" class="status" id="statusBox">
            1) 주제를 뽑은 뒤 2) 생각 정리 시작 버튼으로 1분 준비하고 3) 말하기 시작 버튼을 누르면
            1분 녹음과 텍스트 변환이 동시에 진행됩니다.
          </div>

          <div class="grid-2">
            <button id="prepBtn" disabled>생각 정리 시작</button>
            <button id="startBtn" disabled>말하기 시작</button>
            <button id="stopBtn" class="secondary" disabled>녹음 중지</button>
            <button id="resetBtn" class="secondary">전체 초기화</button>
          </div>

          <audio id="audioPlayer" controls></audio>
          <div class="note">
            텍스트 변환은 Chrome 계열 브라우저에서 가장 잘 작동합니다. 일부 브라우저에서는 음성 인식이 제한될 수 있습니다.
          </div>
        </div>

        <div class="card">
          <div class="section-title">Transcript</div>
          <div class="mono-title">내가 말한 내용</div>
          <div class="output-box" id="transcriptBox">아직 텍스트 변환 결과가 없습니다.</div>
        </div>

        <div class="card">
          <div class="section-title">Feedback</div>
          <div class="mono-title">원어민식 표현 제안</div>
          <div class="output-box small" id="naturalBox">말하기를 마치면 더 자연스러운 표현으로 다듬어드립니다.</div>

          <div class="mono-title" style="margin-top: 18px;">AI 스타일 피드백</div>
          <div class="output-box" id="feedbackBox">피드백이 여기에 표시됩니다.</div>
        </div>
      </div>
    </div>
  </div>

  <script>
    const topics = [
      "If you could live in any country for one year, where would you go and why?",
      "What daily habit improved your life the most?",
      "Is social media more helpful or more harmful?",
      "What book, movie, or drama changed your way of thinking?",
      "Should students learn more practical skills at university?",
      "What makes a city a good place to live?",
      "Would you rather have more money or more free time?",
      "How is AI changing everyday life?",
      "What is one problem in society you want to solve?",
      "Why do people enjoy traveling?",
      "What does success mean to you?",
      "Should animals be kept in zoos?",
      "What is the best way to make new friends?",
      "How can people stay healthy in a busy life?",
      "What tradition from your country would you like to share?",
      "Do you think competition is always good?",
      "What is one skill everyone should learn?",
      "How can technology improve education?",
      "What place helps you feel calm and focused?",
      "Is it better to plan everything or be spontaneous?",
      "How should we respond to climate change?",
      "What job would you never want to do?",
      "What invention are you most thankful for?",
      "Should people work from home more often?"
    ];

    const canvas = document.getElementById("wheelCanvas");
    const ctx = canvas.getContext("2d");
    const spinBtn = document.getElementById("spinBtn");
    const rerollBtn = document.getElementById("rerollBtn");
    const prepBtn = document.getElementById("prepBtn");
    const startBtn = document.getElementById("startBtn");
    const stopBtn = document.getElementById("stopBtn");
    const resetBtn = document.getElementById("resetBtn");
    const selectedTopic = document.getElementById("selectedTopic");
    const prepTimerEl = document.getElementById("prepTimer");
    const speakTimerEl = document.getElementById("speakTimer");
    const statusBox = document.getElementById("statusBox");
    const transcriptBox = document.getElementById("transcriptBox");
    const naturalBox = document.getElementById("naturalBox");
    const feedbackBox = document.getElementById("feedbackBox");
    const audioPlayer = document.getElementById("audioPlayer");

    let rotation = 0;
    let currentTopic = "";
    let prepInterval = null;
    let speakInterval = null;
    let mediaRecorder = null;
    let audioChunks = [];
    let recognition = null;
    let recognitionRunning = false;
    let finalTranscript = "";
    let liveTranscript = "";

    function drawWheel() {
      const center = canvas.width / 2;
      const radius = center - 10;
      const angle = (2 * Math.PI) / topics.length;

      ctx.clearRect(0, 0, canvas.width, canvas.height);

      for (let i = 0; i < topics.length; i++) {
        ctx.beginPath();
        ctx.moveTo(center, center);
        ctx.arc(center, center, radius, i * angle, (i + 1) * angle);
        ctx.fillStyle = i % 2 === 0 ? "#000000" : "#ffffff";
        ctx.fill();
        ctx.lineWidth = 2;
        ctx.strokeStyle = "#000000";
        ctx.stroke();

        ctx.save();
        ctx.translate(center, center);
        ctx.rotate(i * angle + angle / 2);
        ctx.textAlign = "right";
        ctx.fillStyle = i % 2 === 0 ? "#ffffff" : "#000000";
        ctx.font = "700 20px Arial, sans-serif";
        const label = topics[i].length > 22 ? topics[i].slice(0, 22) + "…" : topics[i];
        ctx.fillText(label, radius - 18, 7);
        ctx.restore();
      }

      ctx.beginPath();
      ctx.arc(center, center, 68, 0, Math.PI * 2);
      ctx.fillStyle = "#000000";
      ctx.fill();
      ctx.fillStyle = "#ffffff";
      ctx.font = "700 24px Arial, sans-serif";
      ctx.textAlign = "center";
      ctx.textBaseline = "middle";
      ctx.fillText("SPIN", center, center - 12);
      ctx.fillText("TOPIC", center, center + 16);
    }

    function formatTime(sec) {
      const m = String(Math.floor(sec / 60)).padStart(2, "0");
      const s = String(sec % 60).padStart(2, "0");
      return `${m}:${s}`;
    }

    function setStatus(text) {
      statusBox.innerHTML = text;
    }

    function chooseTopic() {
      const normalized = ((rotation % 360) + 360) % 360;
      const unit = 360 / topics.length;
      const index = Math.floor((topics.length - normalized / unit) % topics.length);
      return topics[index];
    }

    function spinWheel() {
      clearInterval(prepInterval);
      clearInterval(speakInterval);
      prepTimerEl.textContent = "01:00";
      speakTimerEl.textContent = "01:00";
      startBtn.disabled = true;
      stopBtn.disabled = true;
      prepBtn.disabled = true;

      const extra = Math.floor(Math.random() * 360 + 1800);
      rotation += extra;
      canvas.style.transform = `rotate(${rotation}deg)`;

      setStatus("룰렛이 돌아가는 중입니다. 오늘의 주제를 기다려보세요.");

      setTimeout(() => {
        currentTopic = chooseTopic();
        selectedTopic.textContent = currentTopic;
        prepBtn.disabled = false;
        setStatus("주제가 정해졌습니다. 이제 <strong>생각 정리 시작</strong> 버튼을 눌러 1분 동안 말할 내용을 정리해보세요.");
      }, 4200);
    }

    function startPrep() {
      let time = 60;
      prepBtn.disabled = true;
      startBtn.disabled = true;
      spinBtn.disabled = true;
      rerollBtn.disabled = true;
      setStatus("생각 정리 시간입니다. 의견 → 이유 → 예시 순서로 떠올리면 1분 말하기가 훨씬 쉬워집니다.");

      prepTimerEl.textContent = formatTime(time);
      clearInterval(prepInterval);
      prepInterval = setInterval(() => {
        time--;
        prepTimerEl.textContent = formatTime(time);
        if (time <= 0) {
          clearInterval(prepInterval);
          startBtn.disabled = false;
          spinBtn.disabled = false;
          rerollBtn.disabled = false;
          setStatus("준비가 끝났습니다. <strong>말하기 시작</strong> 버튼을 누르면 1분 녹음과 텍스트 변환이 함께 시작됩니다.");
        }
      }, 1000);
    }

    function getSpeechRecognition() {
      return window.SpeechRecognition || window.webkitSpeechRecognition || null;
    }

    function startRecognition() {
      const SR = getSpeechRecognition();
      if (!SR) return false;

      recognition = new SR();
      recognition.lang = "en-US";
      recognition.continuous = true;
      recognition.interimResults = true;

      finalTranscript = "";
      liveTranscript = "";
      transcriptBox.textContent = "텍스트 변환 중입니다...";

      recognition.onresult = (event) => {
        let interim = "";
        for (let i = event.resultIndex; i < event.results.length; i++) {
          const txt = event.results[i][0].transcript;
          if (event.results[i].isFinal) finalTranscript += txt + " ";
          else interim += txt;
        }
        liveTranscript = interim;
        transcriptBox.textContent = (finalTranscript + liveTranscript).trim() || "텍스트 변환 중입니다...";
      };

      recognition.onerror = () => {};
      recognition.onend = () => {
        recognitionRunning = false;
      };

      recognition.start();
      recognitionRunning = true;
      return true;
    }

    function stopRecognition() {
      if (recognition && recognitionRunning) {
        try { recognition.stop(); } catch (e) {}
      }
    }

    async function startRecording() {
      audioChunks = [];
      transcriptBox.textContent = "텍스트 변환 중입니다...";
      naturalBox.textContent = "분석 중입니다...";
      feedbackBox.textContent = "분석 중입니다...";

      try {
        const stream = await navigator.mediaDevices.getUserMedia({ audio: true });
        mediaRecorder = new MediaRecorder(stream);

        mediaRecorder.ondataavailable = e => {
          if (e.data.size > 0) audioChunks.push(e.data);
        };

        mediaRecorder.onstop = () => {
          const blob = new Blob(audioChunks, { type: "audio/webm" });
          audioPlayer.src = URL.createObjectURL(blob);
          stream.getTracks().forEach(track => track.stop());
        };

        mediaRecorder.start();
      } catch (e) {
        setStatus("마이크 사용이 차단되어 녹음을 시작할 수 없습니다. 브라우저에서 마이크 권한을 허용해주세요.");
        return;
      }

      const speechSupported = startRecognition();
      if (!speechSupported) {
        transcriptBox.textContent = "이 브라우저에서는 자동 텍스트 변환이 제한될 수 있습니다. Chrome에서 사용하면 가장 잘 작동합니다.";
      }

      let time = 60;
      speakTimerEl.textContent = formatTime(time);
      setStatus("지금부터 1분 동안 영어로 말해보세요. 자연스럽게 끝까지 이어가는 데 집중하면 됩니다.");

      clearInterval(speakInterval);
      speakInterval = setInterval(() => {
        time--;
        speakTimerEl.textContent = formatTime(time);
        if (time <= 0) {
          stopRecording(true);
        }
      }, 1000);
    }

    function normalizeText(text) {
      return text
        .replace(/\s+/g, " ")
        .replace(/\bi think that\b/gi, "I think")
        .replace(/\bin my opinion\b/gi, "Personally")
        .replace(/\bvery very\b/gi, "really")
        .trim();
    }

    function makeNativeLikeVersion(text) {
      if (!text || text.length < 4) {
        return "텍스트가 충분하지 않아 자연스러운 표현 제안을 만들지 못했습니다.";
      }

      let revised = "A more natural version:\n\n" + normalizeText(text)
        .replace(/\ba lot of\b/gi, "a lot of")
        .replace(/\bI think\b/gi, "I’d say")
        .replace(/\bbecause\b/gi, "mainly because")
        .replace(/\bI like\b/gi, "I really like")
        .replace(/\bI want to\b/gi, "I’d like to")
        .replace(/\bit is\b/gi, "it’s")
        .replace(/\bdo not\b/gi, "don’t")
        .replace(/\bcannot\b/gi, "can’t")
        .replace(/\bI am\b/gi, "I’m")
        .replace(/\bfor example\b/gi, "for instance")
        .replace(/\bvery\b/gi, "really");

      return revised;
    }

    function buildFeedback(text) {
      if (!text || text.length < 4) {
        return "아직 분석할 만한 텍스트가 충분하지 않습니다.\n\n다음에는 한두 문장이라도 끝까지 말해보세요.";
      }

      const words = text.toLowerCase().match(/[a-z']+/g) || [];
      const fillers = ["um", "uh", "like", "you know", "actually", "basically"];
      let fillerCount = 0;

      fillers.forEach(f => {
        const pattern = new RegExp(`\\b${f.replace(" ", "\\s+")}\\b`, "gi");
        const found = text.match(pattern);
        if (found) fillerCount += found.length;
      });

      const sentenceCount = (text.match(/[.!?]/g) || []).length || 1;
      const wordCount = words.length;
      const avgSentence = Math.max(1, Math.round(wordCount / sentenceCount));

      const suggestions = [];

      if (wordCount < 35) {
        suggestions.push("말한 분량이 조금 짧았습니다. 다음에는 의견 1개, 이유 2개, 예시 1개 구조로 말하면 1분을 더 안정적으로 채울 수 있습니다.");
      } else {
        suggestions.push("1분 분량으로는 꽤 괜찮았습니다. 말이 끊기지 않도록 흐름을 유지한 점이 좋습니다.");
      }

      if (fillerCount >= 4) {
        suggestions.push(`'um', 'like' 같은 군더더기 표현이 ${fillerCount}번 정도 보입니다. 침묵이 잠깐 생겨도 괜찮으니 filler를 줄이면 훨씬 자연스럽게 들립니다.`);
      } else {
        suggestions.push("군더더기 표현이 많지 않아 듣는 사람이 내용을 따라가기 좋습니다.");
      }

      if (avgSentence > 18) {
        suggestions.push("문장이 조금 길게 이어질 가능성이 있습니다. 한 문장을 짧게 끊어 말하면 훨씬 또렷하고 원어민식 리듬에 가까워집니다.");
      } else {
        suggestions.push("문장 길이가 비교적 안정적입니다. 짧게 끊어 말하는 감각이 좋습니다.");
      }

      suggestions.push("원어민 느낌을 더 내고 싶다면 'I think'만 반복하기보다 'I’d say', 'Personally', 'One reason is', 'What stands out to me is' 같은 시작 표현을 섞어보세요.");
      suggestions.push("마지막 한 문장은 결론처럼 정리하면 더 자연스럽습니다. 예: 'So overall, that’s why this topic matters to me.'");

      return suggestions.map((s, i) => `${i + 1}. ${s}`).join("\n\n");
    }

    function finalizeTranscriptAndFeedback() {
      const fullText = (finalTranscript + " " + liveTranscript).trim();
      if (fullText) {
        transcriptBox.textContent = fullText;
        naturalBox.textContent = makeNativeLikeVersion(fullText);
        feedbackBox.textContent = buildFeedback(fullText);
      } else {
        transcriptBox.textContent = "텍스트 변환 결과가 없었습니다. 브라우저 음성 인식이 꺼져 있거나 지원되지 않을 수 있습니다.";
        naturalBox.textContent = "Chrome 브라우저에서 다시 시도하면 텍스트 변환이 더 잘 작동할 수 있습니다.";
        feedbackBox.textContent = "녹음은 완료되었지만 텍스트 분석을 위한 음성 인식 결과가 없어 피드백을 생성하지 못했습니다.";
      }
    }

    function stopRecording(auto = false) {
      clearInterval(speakInterval);
      stopBtn.disabled = true;
      spinBtn.disabled = false;
      rerollBtn.disabled = false;
      prepBtn.disabled = false;
      startBtn.disabled = false;

      if (mediaRecorder && mediaRecorder.state !== "inactive") {
        mediaRecorder.stop();
      }

      stopRecognition();

      setTimeout(() => {
        finalizeTranscriptAndFeedback();
      }, 700);

      setStatus(
        auto
          ? "1분 말하기가 완료되었습니다. 아래에서 텍스트 변환 결과와 더 자연스러운 표현 피드백을 확인해보세요."
          : "녹음을 중지했습니다. 아래에서 텍스트 변환 결과와 피드백을 확인해보세요."
      );
    }

    function resetAll() {
      location.reload();
    }

    spinBtn.addEventListener("click", spinWheel);
    rerollBtn.addEventListener("click", spinWheel);
    prepBtn.addEventListener("click", startPrep);
    startBtn.addEventListener("click", () => {
      startBtn.disabled = true;
      stopBtn.disabled = false;
      prepBtn.disabled = true;
      spinBtn.disabled = true;
      rerollBtn.disabled = true;
      startRecording();
    });
    stopBtn.addEventListener("click", () => stopRecording(false));
    resetBtn.addEventListener("click", resetAll);

    drawWheel();
  </script>
</body>
</html>
